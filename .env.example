# GCP Project
PROJECT_ID=your_gcp_project_id
REGION=us-central1

# VPC network used for Direct VPC Egress
VPC_NETWORK=default

# Subnet used by Cloud Run instances for Direct VPC Egress
# Must exist in the VPC above and have sufficient IP space for Cloud Run instances
VPC_SUBNET=snowflake-proxy-subnet

# Snowflake account hostname — the proxy forwards all requests to this host
SNOWFLAKE_HOST=myaccount.snowflakecomputing.com
SNOWFLAKE_PORT=443

# Static egress IP (reserved regionally — NOT --global)
NAT_IP_NAME=snowflake-proxy-nat-ip

# Cloud Router and NAT gateway names
NAT_ROUTER_NAME=snowflake-router
NAT_GATEWAY_NAME=snowflake-proxy-nat

# Cloud Run service name
CLOUD_RUN_SERVICE_NAME=snowflake-proxy

# Artifact Registry repository (created by the script if it doesn't exist)
AR_REPO=snowflake-proxy
