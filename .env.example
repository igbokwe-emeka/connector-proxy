# GCP Project
PROJECT_ID=your_gcp_project_id
REGION=us-central1

# VPC that the Serverless VPC Access Connector bridges into
VPC_NETWORK=default

# Snowflake account hostname — the proxy forwards all requests to this host
SNOWFLAKE_HOST=myaccount.snowflakecomputing.com
SNOWFLAKE_PORT=443

# Static egress IP (reserved regionally — NOT --global)
NAT_IP_NAME=snowflake-proxy-nat-ip

# Cloud Router and NAT gateway names
NAT_ROUTER_NAME=snowflake-router
NAT_GATEWAY_NAME=snowflake-proxy-nat

# Serverless VPC Access Connector — must be a dedicated /28 named subnet
VPC_CONNECTOR_NAME=snowflake-proxy-connector
VPC_CONNECTOR_SUBNET=snowflake-connector-subnet

# Cloud Run service name
CLOUD_RUN_SERVICE_NAME=snowflake-proxy

# Artifact Registry repository (created by the script if it doesn't exist)
AR_REPO=snowflake-proxy

# Security hardening — Strategy C (secret path)
# Generate with: openssl rand -hex 16
PROXY_SECRET_PATH=your_secret_path_here

# Security hardening — Strategy B (Cloud Armor + Global LB)
# Domain name that will front the Global Load Balancer (you must control DNS).
LB_DOMAIN=proxy.yourdomain.com

# Cloud DNS managed zone name that controls LB_DOMAIN.
# If set, the setup script creates the DNS A record automatically.
# Leave blank to manage DNS manually outside GCP.
CLOUD_DNS_ZONE=your-cloud-dns-zone-name
